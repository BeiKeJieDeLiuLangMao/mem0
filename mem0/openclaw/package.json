{
  "name": "@mem0/openclaw-mem0",
  "version": "0.5.0",
  "type": "module",
  "description": "Mem0 memory backend for OpenClaw — HTTP client to OpenMemory API",
  "license": "Apache-2.0",
  "keywords": [
    "openclaw",
    "plugin",
    "memory",
    "mem0",
    "openmemory"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "dependencies": {},
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
